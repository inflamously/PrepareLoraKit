      "id": "VWk970XqHuVcWebP74hMw",
      "type": "text",
      "x": 2854.0406474764372,
      "y": 4764.706008305627,
      "width": 490.41961669921875,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4bxx843",
      "roundness": null,
      "seed": 63413335,
      "version": 3604,
      "versionNonce": 664536055,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783368239840,
      "link": null,
      "locked": false,
      "text": "Audit Substeps:\n- Pairing Image + Caption exist\n- Corrupt Image Files or Text files\n- Caption Quality empty, too short, too long for\ndiffusion models (Requires Model Type selection\nlike CLIP SD1.5, T5 or LLM Types)\n- Resolution\n- Local Model Caption preflight (Some sentences\nare similiar but words could be missing like a token\nor trigger word)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "tNv9i5k5WD78yAwDYhVLy",
      "originalText": "Audit Substeps:\n- Pairing Image + Caption exist\n- Corrupt Image Files or Text files\n- Caption Quality empty, too short, too long for diffusion models (Requires Model Type selection like CLIP SD1.5, T5 or LLM Types)\n- Resolution\n- Local Model Caption preflight (Some sentences are similiar but words could be missing like a token or trigger word)",
      "autoResize": true,
      "lineHeight": 1.25
    },
